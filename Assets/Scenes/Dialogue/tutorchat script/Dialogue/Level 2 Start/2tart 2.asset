  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 12f37c115253878448593ecff98bb63e, type: 3}
  m_Name: 2tart 2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  characterName: Handler
  npcLines:
  - characterName: Handler
    dialogueText: Now, let's stop wasting any time.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: I will now hook your computer into a call with Lady Bug.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: I had also added a new attack on your list for you to use.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: She might look a little weird to you. I had a call with her before
      hand.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: 'But let''s just say the black hats arejust "too committed" to
      their jobs. '
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: Maybe to the point where they now embody it.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: But worry not. As long as she wont successfully hack your computer,
      you'll be fine.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  playerChoices:
  - choiceText: Are you going to be in the call too?
    nextNode: {fileID: 11400000, guid: 39910004aa688b54e84ec246a7eb7bd7, type: 2}
    choiceSound: {fileID: 0}
