  characterName: Handler
  npcLines:
  - characterName: Handler
    dialogueText: Hyperlinking a text in HTML looks like this.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: <a href = "url"> link text </a>
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: <a href = "url"> linked text </a>
      highlightColor: {r: 0.47843137, g: 0.41568628, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: The <a> element is most important attribute in this tag.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: Because this attribute indicates the link's destination.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: 'The link text is also the only visible to read and will act as
      the clickabke button that can take you to the website. '
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: That really is all to say about the matter. How about you try it
      out?
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: Tell me when you are done. You are free to use any link you want.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
