  - characterName: Dee Bug
    dialogueText: ...
    textColor: {r: 0.51572317, g: 0.23714338, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 5
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
