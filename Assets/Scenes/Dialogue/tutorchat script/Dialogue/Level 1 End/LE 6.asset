  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 12f37c115253878448593ecff98bb63e, type: 3}
  m_Name: LE 6
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  characterName: Handler
  npcLines:
  - characterName: Handler
    dialogueText: For now, we are posponing our plan till tomorrow.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: Or at least once we deviced a new plan.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: So until then, Stay on stand by.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: I hope you enjoyed your little catfight with him.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: Oh and by the way, I decided to run a little business in the sidelines.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: 'I am running a little online shop. Simply to help my comarades
      as they hack. '
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: shop
      highlightColor: {r: 0, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: Just call me any time, and i'll seell you something you can use
      in your battles.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: call
      highlightColor: {r: 0, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: That is all.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: Handler
    dialogueText: See you tomorow.
    textColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 0
    destroyOnNextMessage: 0
  - characterName: System
    dialogueText: '-- Handler closed the memo --

      -- Handler deleted the memo
      --'
    textColor: {r: 0.9, g: 0.9, b: 0.9, a: 1}
    isPlayer: 0
