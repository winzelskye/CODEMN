--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 12f37c115253878448593ecff98bb63e, type: 3}
  m_Name: l2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  characterName: Handler
  npcLines:
  - characterName: System
    dialogueText: --Lady Bug has entered the memo.--
    textColor: {r: 0.9, g: 0.9, b: 0.9, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 2
    isContinuation: 0
    wordHighlights: []
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: Hello again , Lady Bug. I assumed you finally agreed to negotiate?
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Well If It Wasn't Because Of Your Collegue Who Had Impressed Me
      Then I wouldn't Be Here Don't I?
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: That is indeed true.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Well Whatever It Is You And Government Runned Company Wants, Make
      It Quick.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: I Dont Have Much Time.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: Then I will go straight to the point.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: 'Do you know a black hat hacker thet goes on an alias "H@cker"? '
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: There's A Lot Of People With That Alias, You Need To Be More Specific
      Than That Darling.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: His computer icon is an inverted colored version of our company
      logo.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Oh! Him...
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 5
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: What About Him?
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: We had found out that he is planning to shut down every hacker
      server worldwide. Including yours.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: We are simply tasked to stop him. And as one of his aquaintance
      we need your help.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Oh My, Sorry But A No Will Do.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: We'll pay you $100,00.
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: That's Nothing.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Our Paychecks Just Doubled.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Besides, It Would Be Quite Disrespectful For Me Not To Participate
      In The Event.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 4
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  playerChoices:
  - choiceText: What do you even gain for this?
    nextNode: {fileID: 11400000, guid: c414357f14e5d2c45b6dc554c533f2aa, type: 2}
    choiceSound: {fileID: 0}
