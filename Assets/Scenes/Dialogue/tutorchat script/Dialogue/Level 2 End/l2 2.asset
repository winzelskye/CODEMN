  characterName: Handler
  npcLines:
  - characterName: Lady Bug
    dialogueText: 'I Supposed A Hackin Battle Is Unavoidable. '
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: H@cker Had Built An A.I. For Checking User Backgrounds.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: That Way, No Hacker Can Reach Him If That User Is A Part Of Certain
      Companies.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: One Of Those Certain Companies Being Yours.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: 'How Can We Bypass That A.I.? '
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Redirect It's Verification Using HTML Links.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: It's System Checks The Company Name Via Links.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: It's System Is Not Perfect. If You Linked Your User Company Name
      With Something Else.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Like The Golden Hackers website For Example.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: It Will Bypass The Checking And Let You In.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
