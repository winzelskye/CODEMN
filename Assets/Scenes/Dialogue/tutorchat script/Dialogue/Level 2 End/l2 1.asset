  - characterName: Lady Bug
    dialogueText: Sometimes The World Just Need A Little Reset To Get It Working
      Again.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Handler
    dialogueText: Won't shutting all servers affect you too?
    textColor: {r: 1, g: 0.94424546, b: 0, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Do You Really Think We Are That Stupid?
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Of Course Ours Will Remain Active, Silly.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Then We Can Watch The World Go Spirals After The Internet Is Gone.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
