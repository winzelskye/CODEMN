  characterName: Handler
  npcLines:
  - characterName: Lady Bug
    dialogueText: That's Just How Life Works Darling. You Have To Betray Your Friends
      For Your Own Good.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
