    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Besides, If The White Hackers Had Mannaged To Contact Me.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Then It's Only A Matter Of Time Before They Find My Location And
      Arrest Me.
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
    delayAfter: 3
    isContinuation: 0
    wordHighlights:
    - word: White Hat Hackers Association
      highlightColor: {r: 1, g: 1, b: 1, a: 1}
    showAttachedObject: 0
    attachedObjectPrefab: {fileID: 0}
    attachedObjectDelay: 1
    destroyOnNextMessage: 1
  - characterName: Lady Bug
    dialogueText: Is That Correct Handler?
    textColor: {r: 0.735849, g: 0.11338539, b: 0.12886956, a: 1}
    isPlayer: 0
    messageSound: {fileID: 8300000, guid: 2310fdff703bd2c4db3c4c2930812960, type: 3}
