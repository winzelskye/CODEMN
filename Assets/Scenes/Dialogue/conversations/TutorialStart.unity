  m_text: 'Example:

    --------------------------------------------------------------


    //
    Font

    <h1 style="font-family:verdana;">This is a heading</h1>

    <p style="font-family:courier;">This
    is a paragraph.</p>


    //Size

    <h1 style="font-size:300%;">This is a heading</h1>

    <p
    style="font-size:160%;">This is a paragraph.</p>


    --------------------------------------------------------------

'
